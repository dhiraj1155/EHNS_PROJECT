# Copy this file to .env and fill in your values

# Ganache RPC URL (default Ganache UI port)
GANACHE_URL=http://127.0.0.1:7545

# Private key of the first Ganache account (no 0x prefix needed by ethers, but Hardhat accepts 0x too)
# Get this from the Ganache UI: click the key icon next to an account
GANACHE_PRIVATE_KEY=YOUR_GANACHE_PRIVATE_KEY_HERE
