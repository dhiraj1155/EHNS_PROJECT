# Hospital Logs Backend — Environment Variables
# Copy this file to .env and fill in your real values

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://vivekpahilwan:Vivek5055@hospitalcluster.8udlwok.mongodb.net/?appName=HospitalCluster

# ── Ganache / Blockchain ──────────────────────────────────────────────────────
GANACHE_URL=http://127.0.0.1:7545

# Private key of the Ganache account used to sign transactions
# Get this from the Ganache UI (click the 🔑 key icon next to an account)
PRIVATE_KEY=YOUR_GANACHE_PRIVATE_KEY_HERE

# Smart contract address — fill this in after running:
#   cd ../blockchain && npx hardhat run scripts/deploy.js --network ganache
CONTRACT_ADDRESS=YOUR_CONTRACT_ADDRESS_HERE
